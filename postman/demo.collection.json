{
  "info": {
    "name": "Postman API Catalog Demo",
    "description": "Repeatable demo: deploy APIs on Cloudflare → register in API Catalog → measure spec and test quality.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Smoke tests",
      "item": [
        {
          "name": "Orders — health",
          "request": {
            "method": "GET",
            "url": "{{ordersApiUrl}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Orders health OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Orders — list",
          "request": {
            "method": "GET",
            "url": "{{ordersApiUrl}}/orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Orders list OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Orders — OpenAPI",
          "request": {
            "method": "GET",
            "url": "{{ordersApiUrl}}/openapi.json"
          }
        },
        {
          "name": "Payments — health",
          "request": {
            "method": "GET",
            "url": "{{paymentsApiUrl}}/health"
          }
        },
        {
          "name": "Payments — list",
          "request": {
            "method": "GET",
            "url": "{{paymentsApiUrl}}/payments"
          }
        },
        {
          "name": "Users — list",
          "request": {
            "method": "GET",
            "url": "{{usersApiUrl}}/users"
          }
        }
      ]
    },
    {
      "name": "Catalog metrics demo",
      "description": "Run this folder (or a monitor) to feed API Catalog Test tab metrics. Uses ?delay= and ?error= simulation params.",
      "item": [
        {
          "name": "Orders — normal (200)",
          "request": {
            "method": "GET",
            "url": "{{ordersApiUrl}}/orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Orders — slow (2s delay)",
          "request": {
            "method": "GET",
            "url": "{{ordersApiUrl}}/orders?delay=2000"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 after delay', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response took at least 2s', function () {",
                  "  pm.expect(pm.response.responseTime).to.be.above(1900);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Orders — simulated 500",
          "request": {
            "method": "GET",
            "url": "{{ordersApiUrl}}/orders?error=500"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Simulated server error', function () { pm.response.to.have.status(500); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Payments — normal (200)",
          "request": {
            "method": "GET",
            "url": "{{paymentsApiUrl}}/payments"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Payments — slow (3s delay)",
          "request": {
            "method": "GET",
            "url": "{{paymentsApiUrl}}/payments?delay=3000"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 after delay', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response took at least 3s', function () {",
                  "  pm.expect(pm.response.responseTime).to.be.above(2900);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Payments — simulated 503",
          "request": {
            "method": "GET",
            "url": "{{paymentsApiUrl}}/payments?error=503"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Simulated unavailable', function () { pm.response.to.have.status(503); });"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
