# Cloudflare (wrangler login stores credentials; optional explicit token)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# Postman API key — required for ./demo.sh register <api> (API Catalog, Enterprise)
POSTMAN_API_KEY=

# Label for catalog registration (system environment name)
DEMO_ENVIRONMENT=demo

# Worker URLs are written automatically to .demo-state.env after deploy:
# ORDERS_API_URL=
# PAYMENTS_API_URL=
# USERS_API_URL=
