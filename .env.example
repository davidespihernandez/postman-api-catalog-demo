# Cloudflare auth (pick one method)
#
# Method A — OAuth (default): run ./demo.sh setup and complete browser login.
#
# Method B — API token (recommended on corporate VPN/proxy):
#   1. https://dash.cloudflare.com/profile/api-tokens
#   2. Create Token → template "Edit Cloudflare Workers"
#   3. Account ID: from dashboard URL (dash.cloudflare.com/<account_id>/...)
#   4. npx wrangler logout   # if browser login previously failed with 403
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
#
# After auth, register a workers.dev subdomain (one-time, interactive):
#   ./demo.sh setup-subdomain
# Then deploy all APIs:
#   ./demo.sh deploy

# Worker URLs are written automatically to .demo-state.env after deploy:
# ORDERS_API_URL=
# PAYMENTS_API_URL=
# USERS_API_URL=
#
# Payments refund webhook (POST after successful refund). Copy from Postman env refundWebhookUrl:
# REFUND_WEBHOOK_URL=https://7ygtn6bgtcbmv8k2oigij4xc0.webhook.pstmn.io/
